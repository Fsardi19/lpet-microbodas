# Landing page: microbodas
# Copy to .env.local and fill values before deploy.

# Canonical URL of production (set on Vercel)
NEXT_PUBLIC_SITE_URL=https://microbodas.lapalmayeltucanhotel.com

# Cloudinary (pre-configured — no key needed on the client)
NEXT_PUBLIC_CLOUDINARY_CLOUD=dsylu9a7k

# GA4 — pending Felipe (replace G-XXXXXXX)
NEXT_PUBLIC_GA4_ID=

# Meta Pixel — pending Felipe
NEXT_PUBLIC_META_PIXEL_ID=

# Endpoint de envío del formulario corto (Formspree, Getform, webhook n8n, etc.)
# Ejemplo: https://formspree.io/f/xxxxxxxx
NEXT_PUBLIC_FORM_ENDPOINT=
